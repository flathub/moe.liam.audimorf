{
    "id": "moe.liam.audimorf",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node20"
    ],
    "command": "moe.liam.audimorf",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/node20/bin"
    },
    "modules": [
        {
            "name": "audimorf",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://codeberg.org/tehsquidge/Audimorf.git",
                    "tag": "v1.3.0",
                    "commit": "93a8c4a3ef5b2ccb42238a40c94029e76de5f2be"
                }
            ]
        }
    ]
}
